{
  "compilerOptions": {
    "lib": ["ESNext"],
    "experimentalDecorators": true,
    "target": "ES2019",
    "module": "none",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "types": ["google-apps-script"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}