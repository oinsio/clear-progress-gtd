{
  "compilerOptions": {
    "lib": ["ESNext"],
    "experimentalDecorators": true,
    "target": "ES2019",
    "module": "ES2015",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}